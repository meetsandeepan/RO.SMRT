@startuml
skinparam svgDimensionStyle true
left to right direction
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam ArrowThickness 1.5
skinparam ArrowFontSize 10

skinparam component {
  BackgroundColor<<smrt>> #D6EAF8
  BorderColor<<smrt>> #1A5276
  BorderThickness<<smrt>> 2
  FontStyle<<smrt>> bold
  BackgroundColor<<ext>> #F4F6F6
  BorderColor<<ext>> #95A5A6
  FontColor<<ext>> #555555
  BorderThickness<<ext>> 1
}

component "Radiation Oncology\nInformation System (ROIS)" <<smrt>> as ROIS
component "Treatment Management\nSystem (TMS)" <<smrt>> as TMS
component "Hospital Information\nSystem (HIS)" <<ext>> as HIS
component "Object Store (OST)" <<ext>> as OST

' External inbound
HIS .[#95A5A6].> ROIS : <color:#95A5A6><i>Patient Demographics: HL7v2 ADT</i></color>

' SMRT-defined FHIR transactions: ROIS → TMS
ROIS -[#1A5276]-> TMS : Sync Patient Photo [RO-SMRT-01]
ROIS -[#1A5276]-> TMS : Report Treatment Approval [RO-SMRT-03]

' Reused transactions: ROIS → TMS
ROIS .[#95A5A6].> TMS : <color:#95A5A6><i>Patient Demographics [ITI-30]</i></color>
ROIS .[#95A5A6].> TMS : <color:#95A5A6><i>Encounter [ITI-31] (opt.)</i></color>
ROIS .[#95A5A6].> TMS : <color:#95A5A6><i>Appointment / Check-in: HL7v2 SIU</i></color>

' SMRT-defined FHIR transactions: TMS → ROIS
TMS -[#1A5276]-> ROIS : Report Planning Artifacts [RO-SMRT-02]
TMS -[#1A5276]-> ROIS : Report Treatment Artifacts [RO-SMRT-04]
TMS -[#1A5276]-> ROIS : Report Image Review Results [RO-SMRT-05]

' DICOM artifact retrieval
ROIS .[#CA6F1E].> OST : <color:#CA6F1E><i>Retrieve Artifacts: DICOM C-MOVE / WADO-RS</i></color>

' External outbound
ROIS .[#95A5A6].> HIS : <color:#95A5A6><i>Treatment Summary (XRTS/ORU) / Billing (DFT)</i></color>

legend right
  |= Symbol |= Meaning |
  |<back:#D6EAF8>   <b>Actor</b>   </back>| SMRT Actor |
  |<back:#F4F6F6>   Actor   </back>| External / Context Actor |
  |<color:#1A5276>——►</color>| SMRT-defined FHIR transaction |
  |<color:#CA6F1E>- - ►</color>| DICOM artifact retrieval |
  |<color:#95A5A6>- - ►</color>| External / reused transaction |
endlegend
@enduml
