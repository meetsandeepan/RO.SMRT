     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ImplementationGuide ihe.ro.smrt</b></p><a name=\"ihe.ro.smrt\"> </a><a name=\"hcihe.ro.smrt\"> </a><h2>IHE_RO_SMRT</h2><p>The official URL for this implementation guide is: </p><pre>https://profiles.ihe.net/RO/SMRT/ImplementationGuide/ihe.ro.smrt</pre><div><p>Defines the workflow and content necessary to connect any device-specific Treatment Management System (TMS) with a single departmental Radiation Oncology Information System (ROIS), enabling a holistic view of all ongoing treatments.</p>\n</div></div>"^^rdf:XMLLiteral ]
